{
  "manifest_version": 3,
  "name": "Wikipedia Quick Summary",
  "version": "1.0.0",
  "description": "Highlight any text to get instant Wikipedia summaries",
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "https://en.wikipedia.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
